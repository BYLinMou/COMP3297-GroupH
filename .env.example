# Django runtime settings
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,example.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://example.com

# Database
# Supported values: sqlite, postgresql
DATABASE_ENGINE=sqlite
SQLITE_PATH=/data/db.sqlite3

# PostgreSQL settings, used only when DATABASE_ENGINE=postgresql.
POSTGRES_DB=betatrax
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Tenant middleware/backend switch.
# When True, the Docker entrypoint runs migrate_schemas --shared instead of migrate.
ENABLE_DJANGO_TENANTS=False
# Hostnames that should always use the public/platform schema.
# Do not create Domain rows for these hostnames.
PUBLIC_SCHEMA_DOMAINS=platform.localhost
# When True, allowed hosts without a matching tenant domain use the public schema URL set.
SHOW_PUBLIC_IF_NO_TENANT_FOUND=True

# Docker startup migration switch.
# Keep True for one-command deployment. Set False only when migrations are managed externally.
AUTO_MIGRATE=True
DATABASE_WAIT_TIMEOUT=60

# Email (Google SMTP)
# Set EMAIL_ENABLED=True to enable email sending.
EMAIL_ENABLED=False
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-gmail@gmail.com
# Use Google App Password (not your Google account password).
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=BetaTrax <your-gmail@gmail.com>
