# Django runtime settings
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,example.com
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://example.com
SQLITE_PATH=./data/db.sqlite3

# Email (Google SMTP)
# Set EMAIL_ENABLED=True to enable email sending.
EMAIL_ENABLED=False
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-gmail@gmail.com
# Use Google App Password (not your Google account password).
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=BetaTrax <your-gmail@gmail.com>
